# Local: copy to ``.env`` next to ``env.py``. Databricks Job: inject the same keys via environment / Secrets.

# Required for fetch (``python -m notion_ai_usage`` and the Databricks job), unless using Secrets:
NOTION_COOKIE=""

# Databricks only: if NOTION_COOKIE is unset, load from Secrets (scope + key name).
# DATABRICKS_SECRET_SCOPE="cto-notion"
# DATABRICKS_SECRET_KEY_NOTION_COOKIE="notion-cookie"

# Optional: Delta target (Unity Catalog ``catalog.schema.table``). Unset to skip Delta in the job.
# NOTION_AI_DELTA_TABLE="main.analytics.notion_ai_usage_top_entities"

# Optional (Databricks job): export the same tabular data as comma-separated text to a file (DBFS / Volume / local).
# Local CLI prints a text table to stdout; use this on the job only if you need a .csv file.
# NOTION_AI_CSV_PATH="/Volumes/catalog/schema/volume/path/notion_ai_usage.csv"

# Optional: dump raw JSON from the job to stdout (debug).
# NOTION_AI_PRINT_JSON=1
