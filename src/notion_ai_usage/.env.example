# Local: copy to ``.env`` next to ``env.py``. Databricks Job: inject the same keys via environment / Secrets.

# Required for fetch (``python -m notion_ai_usage`` and the Databricks job):
NOTION_COOKIE=""

# Optional: Delta target (Unity Catalog ``catalog.schema.table``). Unset to skip Delta in the job.
# NOTION_AI_DELTA_TABLE="main.analytics.notion_ai_usage_top_entities"

# Optional: dump raw JSON from the job to stdout (debug).
# NOTION_AI_PRINT_JSON=1
